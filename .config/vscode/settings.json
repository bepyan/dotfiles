{
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "cSpell.enabledNotifications": {
    "Average Word Length too Long": false,
    "Lines too Long": false,
    "Maximum Word Length Exceeded": false
  },
  "cSpell.userWords": [
    "astro",
    "autoincrement",
    "bepyan",
    "bigrams",
    "bunx",
    "clsx",
    "darkmode",
    "daum",
    "daumcdn",
    "deepmerge",
    "embla",
    "frontmatter",
    "hono",
    "josa",
    "KAKAO",
    "kakaotalk",
    "libsql",
    "lucide",
    "naver",
    "noti",
    "ofetch",
    "ordnum",
    "oxfmt",
    "oxlint",
    "pagefind",
    "phocus",
    "postbuild",
    "posthog",
    "pretendard",
    "resizeable",
    "rsbuild",
    "rspack",
    "rstest",
    "shiki",
    "stylelint",
    "supabase",
    "tailwindcss",
    "tanstack",
    "tauri",
    "turso",
    "twoslash",
    "ultrawork",
    "vite",
    "worktree"
  ],
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.mouseWheelZoom": true,
  "explorer.confirmDelete": false,
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "onFocusChange",
  // automatically detect git worktree based on open editors
  "git.autoRepositoryDetection": "openEditors",
  "git.confirmSync": false,
  "update.showReleaseNotes": false,
  "workbench.colorTheme": "Vesper",
  "workbench.iconTheme": "material-icon-theme",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "cursor.general.emailPrivacyEnabled": true
}
