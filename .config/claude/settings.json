{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.agents/hooks/pre-edit-checklist.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.agents/hooks/stop-session-log.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "opus[1m]",
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash",
      "mcp__*"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)"
    ]
  },
  "spinnerTipsEnabled": false,
  "statusLine": {
    "command": "bash $HOME/.claude/statusline.sh",
    "type": "command"
  }
}